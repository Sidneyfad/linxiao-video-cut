# Pick ONE of these auth modes:
# (a) Official Anthropic API
ANTHROPIC_API_KEY=
# (b) Bearer-style proxy (DeepSeek / OpenRouter / LiteLLM / etc.)
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Optional model + reasoning config (also tunable in the in-app ⚙ Settings)
# ANTHROPIC_MODEL=claude-opus-4-7

# Required for video transcription
ELEVENLABS_API_KEY=

# Server config (all optional)
# PORT=3000
# SESSIONS_DIR=./sessions
# SESSION_TTL_MS=86400000
# MAX_UPLOAD_SIZE=10737418240
